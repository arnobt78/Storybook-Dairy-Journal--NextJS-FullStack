# --- Next.js ---
# Build output and dev cache (regenerated by `next dev` / `next build`).
.next/
out/

# --- Node.js ---
node_modules/

# --- Environment ---
# Never commit real secrets. `.env.example` stays tracked (not listed here).
.env
.env.local
.env*.local

# --- Database (local SQLite artifacts) ---
# Prisma migrations under prisma/migrations/ should be committed for reproducible schema history.
*.db
*.db-journal

# --- Tooling / OS ---
# Test coverage output, TypeScript incremental build info, Turborepo cache, OS metadata.
coverage/
*.tsbuildinfo
.turbo/
.DS_Store
Thumbs.db

# --- Cursor ---
.cursorignore
.cursor

# --- IDE ---
.idea/
.vscode/

# --- Logs / temp / backup (project-local junk) ---
logs/
temp/
backup/

# npm / yarn debug logs (optional local noise)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Claude
CLAUDE.md
.claude

# Documentation
docs/HETZNER_VPS_MIGRATION_GUIDE.md